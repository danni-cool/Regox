package templates

templ ErrorPage(message string) {
	<main class="max-w-2xl mx-auto px-6 py-32 text-center">
		<p class="text-8xl font-bold text-red-200">500</p>
		<h1 class="text-2xl font-bold text-gray-900 mt-4">Server Error</h1>
		<p class="text-gray-500 mt-2">{ message }</p>
		<a href="/" class="inline-block mt-8 px-6 py-3 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 transition-colors">Go Home</a>
	</main>
}
