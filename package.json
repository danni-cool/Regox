{
  "name": "regox",
  "private": true,
  "scripts": {
    "build:packages": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --filter mvp dev",
    "codegen": "pnpm codegen:ts && pnpm codegen:go",
    "codegen:ts": "openapi-typescript apps/mvp/openapi.yaml -o apps/mvp/frontend/generated/types.ts",
    "codegen:go": "cd apps/mvp/backend && go generate ./..."
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.4.0"
  }
}
